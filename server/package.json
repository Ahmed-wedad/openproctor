{
  "name": "openproctor-server",
  "version": "1.0.0",
  "description": "Backend microservice for OpenProctor: telemetry ingestion (Redis-buffered), snapshot storage (MinIO), and review API (PostgreSQL).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:init": "psql \"$DB_URL\" -f src/schema.sql"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "minio": "^7.1.3",
    "multer": "^2.2.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.5.4",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
