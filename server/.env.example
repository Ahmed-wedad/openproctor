# OpenProctor microservice configuration

# Server
PORT=4000

# PostgreSQL
DB_URL=postgres://openproctor:openproctor@localhost:5432/openproctor

# Redis (write-behind cache for telemetry)
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible object storage for snapshots)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=openproctor-snapshots

# Violation flagging
CONSECUTIVE_VIOLATIONS_THRESHOLD=5
