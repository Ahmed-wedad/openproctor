# OpenProctor vendor frontend (Next.js, standalone output).
# This is the EXTERNAL origin that runs the proprietary camera/AI code — it is
# NEVER bundled into TAO's AGPL deliver bundle. Served at OPENPROCTOR_FRONTEND_URL.
FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install

FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
EXPOSE 3000
CMD ["node", "server.js"]
